# Copy this file to .env and fill in ONE provider.   cp .env.example .env

# --- Grok / xAI (default; free key at https://console.x.ai) ---
# Grok is OpenAI-compatible, so this same code also works with OpenAI.
XAI_API_KEY=
XAI_MODEL=grok-4.3

# --- OpenAI / Azure OpenAI (optional alternative) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Which provider to use: grok | openai
PROVIDER=grok

# No key? Set to 1 to run with a fake model (the agent loop still works offline).
USE_MOCK=0
